# Copy this file to .env and fill in your real Confluent Cloud values.
# NEVER commit the real .env file -- it's in .gitignore for a reason.
#
# common.py loads this file automatically via python-dotenv, so you do
# NOT need to `export` (bash/macOS/Linux) or `set` (Windows cmd) or
# `$env:` (PowerShell) anything yourself -- just having a .env file
# with these values, in the same folder you run the scripts from, is
# enough on any OS.
#
# In the actual Databricks platform, these same three values come from
# Azure Key Vault via a Databricks secret scope, not a .env file.
# This local file exists only so you can run these producer scripts from
# your own machine while building/testing the Kafka POC.

KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.eastus.azure.confluent.cloud:9092
KAFKA_API_KEY=your-confluent-api-key
KAFKA_API_SECRET=your-confluent-api-secret

KAFKA_ORDERS_TOPIC=orders
KAFKA_INVENTORY_TOPIC=inventory
